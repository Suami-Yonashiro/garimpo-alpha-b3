# ===================================================================
# MODELO de variaveis de ambiente — Garimpo Alpha B3
# -------------------------------------------------------------------
# COMO USAR:
#   1. Copie este arquivo para ".env"  (cp .env.example .env)
#   2. Preencha os valores reais do seu projeto Supabase no .env
#   3. O .env NUNCA vai pro Git (ja esta no .gitignore) — so este modelo vai.
#
# Onde achar no painel do Supabase:
#   SUPABASE_DB_URL  -> Settings > Database > Connection pooling (use o pooler!)
#   SUPABASE_URL     -> Settings > API > Project URL
#   SUPABASE_ANON_KEY-> Settings > API > Project API keys > anon public
#   SERVICE_ROLE     -> Settings > API > service_role  (SECRETA — poder total)
# ===================================================================

# String de conexao Postgres via SESSION POOLER (IPv4, porta 5432) — recomendado
# para este projeto (compativel com dbt/SQLAlchemy). NAO use a "Direct connection"
# (so IPv6). Copie a string exata do botao "Connect" do Supabase e troque [SUA-SENHA].
# ATENCAO ao preencher o .env: APAGUE a linha de exemplo inteira e cole a sua no lugar
# (nao cole depois do "postgresql://" — senao o prefixo fica duplicado e a conexao falha).
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxx:[SUA-SENHA]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# REST API (uso futuro / dashboard)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
